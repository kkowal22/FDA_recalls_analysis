      "source": "# =============================================================================\n# CHART A: LATENCY & INCIDENT TRENDS OVER TIME (Task 2 - Side Legend)\n# =============================================================================\n# Group data by Year to calculate metrics explicitly and protect against outliers\ndf_events = df.drop_duplicates(subset=['Event ID']).copy()\n \n# Group data by Year to calculate metrics explicitly and protect against outliers\ndf_annual = df_events.groupby('Year').agg(\n    total_recall_volume=('Event ID', 'nunique'),\n    median_processing_latency=('Latency_Days', 'median')\n).reset_index()\n \n# Initialize the selection variable for interactivity\ntime_brush = alt.selection_interval(encodings=['x'])\n \n# Build the base chart using the annual aggregated dataframe\nbase_time = alt.Chart(df_annual).encode(\n    alt.X('Year:O', title='Year of Recall Initiation')\n).properties(width=600, height=280)\n \n# Layer 1: Vertical Bars for Total Annual Recall Volume\nvolume_bars = base_time.mark_bar(opacity=0.85).encode(\n    alt.Y('total_recall_volume:Q', title='Total Annual Recalls (Unique Event IDs)'),\n    color=alt.Color('series_vol:N',\n                    scale=alt.Scale(range=['#b4c6e7']),\n                    legend=alt.Legend(title='Volume Metric', orient='right'))\n).transform_calculate(\n    series_vol='\"Total Recall Volume\"'\n).add_params(time_brush)\n \n# Layer 2: Trend Line for Median Processing Latency\nlatency_line = base_time.mark_line(strokeWidth=3, point=True).encode(\n    alt.Y('median_processing_latency:Q', title='Median Processing Delay (Days)'),\n    color=alt.Color('series_lat:N',\n                    scale=alt.Scale(range=['#1f4e78']),\n                    legend=alt.Legend(title='Latency Metric', orient='right'))\n).transform_calculate(\n    series_lat='\"Median Processing Delay\"'\n)\n \n# Combine layers together with dual independent axes for both Y and Color\nchart_timeline = alt.layer(volume_bars, latency_line).resolve_scale(\n    y='independent',\n    color='independent'  # Forces separate color identities so both legends render on the right side\n).properties(\n    title=alt.TitleParams(\n        text=\"Administrative Latency vs. Total Recall Volume Trends\",\n        subtitle=\"Click and drag horizontally to brush years.\"\n    )\n)\n \n# Render the visualization\nchart_timeline",
